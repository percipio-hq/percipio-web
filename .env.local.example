# .env.local.example — copy to .env.local and fill in your values
# .env.local is gitignored and must never be committed

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=percipio-base.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=percipio-base
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=percipio-base.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Telegram (server-side only — never expose to client)
TELEGRAM_BOT_TOKEN=your-bot-token
# Your chat ID — get it by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=your-chat-id

# Firebase Admin SDK service account (server-side only, for Telegram /status webhook)
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Minify the downloaded JSON to a single line and paste it here
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# RFID card → Firebase Auth credentials mapping (server-side only)
# Format: JSON object where key = card UID (uppercase, no spaces), value = { email, password }
# Get the UID from Serial Monitor after running test_rfid.ino on the ESP32
# Example: RFID_CARDS={"A1B2C3D4":{"email":"jacek@gmail.com","password":"yourpassword"}}
RFID_CARDS={}
