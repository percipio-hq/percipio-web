# .env.local.example — copy to .env.local and fill in your values
# .env.local is gitignored and must never be committed

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=percipio-base.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=percipio-base
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=percipio-base.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Telegram (server-side only — never expose to client)
TELEGRAM_BOT_TOKEN=your-bot-token
